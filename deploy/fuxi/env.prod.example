COMPOSE_PROJECT_NAME=fuxi-api-prod
IMAGE=ghcr.io/jiutubaba/fx-api:latest
REDIS_IMAGE=redis:8.4-alpine
APP_CONTAINER_NAME=fuxi-api-prod
REDIS_CONTAINER_NAME=fuxi-api-prod-redis
BIND_HOST=127.0.0.1
SERVER_PORT=3300
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=fuxi_api_prod
DATABASE_PASSWORD=change_me
DATABASE_DBNAME=fuxi_api_prod
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=256
DATABASE_MAX_IDLE_CONNS=128

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

ADMIN_EMAIL=admin@fuxiapi.top
ADMIN_PASSWORD=
JWT_SECRET=
TOTP_ENCRYPTION_KEY=
LOG_SERVICE_NAME=fuxi-api-prod
LOG_ENV=production

# Used only by ./migrate.sh. Keep real values on the server; do not commit secrets.
NEWAPI_SOURCE_DSN=
FUXI_TARGET_DSN=
