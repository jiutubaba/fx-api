COMPOSE_PROJECT_NAME=fuxi-api-staging
IMAGE=ghcr.io/jiutubaba/fx-api:latest
REDIS_IMAGE=redis:8.4-alpine
APP_CONTAINER_NAME=fuxi-api-staging
REDIS_CONTAINER_NAME=fuxi-api-staging-redis
POSTGRES_NETWORK_NAME=new-api-net
BIND_HOST=127.0.0.1
SERVER_PORT=3200
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

DATABASE_HOST=new-api-postgres
DATABASE_PORT=5432
DATABASE_USER=fuxi_api_staging
DATABASE_PASSWORD=change_me
DATABASE_DBNAME=fuxi_api_staging
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

ADMIN_EMAIL=admin@fuxiapi.top
ADMIN_PASSWORD=
JWT_SECRET=
TOTP_ENCRYPTION_KEY=
LOG_SERVICE_NAME=fuxi-api-staging
LOG_ENV=staging

# Used only by ./migrate.sh. Keep real values on the server; do not commit secrets.
NEWAPI_SOURCE_DSN=
FUXI_TARGET_DSN=
